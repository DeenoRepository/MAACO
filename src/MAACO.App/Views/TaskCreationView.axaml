<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAACO.App.ViewModels"
             x:DataType="vm:TaskCreationViewModel"
             x:Class="MAACO.App.Views.TaskCreationView">
    <StackPanel Spacing="14">
        <TextBlock Text="Task Creation" Classes="heading" />
        <TextBlock Text="Create execution requests with clear constraints and approval behavior." Classes="muted" />

        <Border Classes="card" Padding="14">
            <StackPanel Spacing="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="Task Input" FontSize="16" FontWeight="SemiBold" />
                    <Button DockPanel.Dock="Right" Content="Refresh Projects" Command="{Binding LoadProjectsCommand}" />
                </DockPanel>
                <ProgressBar Height="8" IsIndeterminate="{Binding IsBusy}" />

                <TextBlock Text="Project" />
                <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Title" />
                <TextBox Text="{Binding TaskTitle}" PlaceholderText="Implement feature X" />

                <TextBlock Text="Description" />
                <TextBox Text="{Binding TaskDescription}" AcceptsReturn="True" Height="90" TextWrapping="Wrap" />

                <TextBlock Text="Constraints" />
                <TextBox Text="{Binding Constraints}" AcceptsReturn="True" Height="90" TextWrapping="Wrap" />

                <TextBlock Text="Approval Mode" />
                <ComboBox ItemsSource="{Binding ApprovalModes}" SelectedItem="{Binding SelectedApprovalMode}" />

                <Button Classes="primary" Content="Create Task" Command="{Binding CreateTaskCommand}" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Classes="muted" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
