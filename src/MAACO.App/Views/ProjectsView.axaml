<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAACO.App.ViewModels"
             x:DataType="vm:ProjectsViewModel"
             x:Class="MAACO.App.Views.ProjectsView">
    <StackPanel Spacing="14">
        <TextBlock Text="Projects" Classes="heading" />
        <TextBlock Text="Register repository workspaces and bootstrap metadata for autonomous runs." Classes="muted" />

        <Grid ColumnDefinitions="2*,3*" ColumnSpacing="14">
            <Border Grid.Column="0" Classes="card" Padding="14">
                <StackPanel Spacing="10">
                    <TextBlock Text="Repository Onboarding" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Folder path" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding SelectedFolderPath}" PlaceholderText="D:\Projects\Repo" />
                        <Button Grid.Column="1" Content="Browse..." Click="BrowseFolder_Click" />
                    </Grid>

                    <TextBlock Text="Project name" />
                    <TextBox Text="{Binding ProjectName}" PlaceholderText="Backend Service" />

                    <WrapPanel Orientation="Horizontal" ItemWidth="150" Margin="0,6,0,0">
                        <Button Classes="primary" Content="Use Current Folder" Command="{Binding UseCurrentFolderCommand}" />
                        <Button Classes="primary" Content="Add + Scan" Command="{Binding AddAndScanProjectCommand}" />
                    </WrapPanel>
                    <ProgressBar Height="8" IsIndeterminate="{Binding IsBusy}" />
                    <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Classes="muted" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="14">
                <StackPanel Spacing="8">
                    <TextBlock Text="Detected Configuration" FontWeight="SemiBold" FontSize="16" />
                    <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tech stack" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetectedStack}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Build command" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BuildCommand}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Test command" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TestCommand}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="File summary" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ProjectFilesSummary}" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
