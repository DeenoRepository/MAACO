<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAACO.App.ViewModels"
             x:DataType="vm:IScreenViewModel"
             x:Class="MAACO.App.Views.ScreenView">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="10">
            <TextBlock Text="{Binding Title}" Classes="heading" />
            <TextBlock Text="{Binding Description}" Classes="muted" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
