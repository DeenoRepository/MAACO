<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAACO.App.ViewModels"
             x:DataType="vm:DiffReviewViewModel"
             x:Class="MAACO.App.Views.DiffReviewView">
    <Border Padding="24" CornerRadius="10" Background="#112A2D34">
        <StackPanel Spacing="10">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.85" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding TaskId}" PlaceholderText="Task Id (GUID)" />
                <Button Grid.Column="1" Content="Load Diff" Command="{Binding LoadDiffCommand}" />
            </Grid>
            <TextBlock Text="{Binding DiffStatus}" />
            <TextBlock Text="Changed Files" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
            <Border Padding="8" Background="#0A141E" CornerRadius="8" Height="130">
                <ListBox ItemsSource="{Binding ChangedFiles}" />
            </Border>
            <TextBlock Text="Unified Diff" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
            <Border Padding="8" Background="#0A141E" CornerRadius="8" Height="260">
                <ListBox ItemsSource="{Binding DiffLines}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:DiffLineViewModel">
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding Foreground}"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <TextBlock Text="Generated Commit Message" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
            <Border Padding="8" Background="#0A141E" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Template"
                               FontWeight="SemiBold"
                               Opacity="0.85" />
                    <TextBlock Text="{Binding GeneratedCommitMessage}"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               TextWrapping="Wrap"
                               Opacity="0.8" />
                    <TextBlock Text="Editable"
                               FontWeight="SemiBold"
                               Opacity="0.85" />
                    <TextBox Text="{Binding EditableCommitMessage}"
                             AcceptsReturn="True"
                             MinHeight="90"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Code, Consolas, monospace" />
                    <Button Content="Reset To Template"
                            HorizontalAlignment="Left"
                            Command="{Binding ResetCommitMessageCommand}" />
                </StackPanel>
            </Border>
            <TextBlock Text="Approval" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
            <TextBox Text="{Binding RejectReason}"
                     PlaceholderText="Reject reason (optional)"
                     TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Approve" Command="{Binding ApproveCommand}" />
                <Button Content="Reject" Command="{Binding RejectCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding ApprovalStatusMessage}" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
