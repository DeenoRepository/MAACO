<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAACO.App.ViewModels"
             x:DataType="vm:DiffReviewViewModel"
             x:Class="MAACO.App.Views.DiffReviewView">
    <StackPanel Spacing="12">
        <TextBlock Text="{Binding Title}" Classes="heading" />
        <TextBlock Text="{Binding Description}" Classes="muted" TextWrapping="Wrap" />

        <Border Classes="card" Padding="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding TaskId}" PlaceholderText="Task Id (GUID)" />
                <Button Grid.Column="1" Classes="primary" Content="Load Diff" Command="{Binding LoadDiffCommand}" />
            </Grid>
        </Border>

        <TextBlock Text="{Binding DiffStatus}" Classes="muted" />

        <Grid ColumnDefinitions="2*,3*" ColumnSpacing="12">
            <Border Grid.Column="0" Classes="card" Padding="10">
                <StackPanel Spacing="8">
                    <TextBlock Text="Changed Files" FontWeight="SemiBold" FontSize="16" />
                    <Border Classes="surface" Height="180" Padding="8">
                        <ListBox ItemsSource="{Binding ChangedFiles}" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="10">
                <StackPanel Spacing="8">
                    <TextBlock Text="Unified Diff" FontWeight="SemiBold" FontSize="16" />
                    <Border Classes="surface" Height="300" Padding="8">
                        <ListBox ItemsSource="{Binding DiffLines}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DiffLineViewModel">
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="{Binding Foreground}"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               TextWrapping="NoWrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Classes="card" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Commit Message" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Text="Template" FontWeight="SemiBold" Classes="muted" />
                <TextBlock Text="{Binding GeneratedCommitMessage}" FontFamily="Cascadia Code, Consolas, monospace" TextWrapping="Wrap" />
                <TextBlock Text="Editable" FontWeight="SemiBold" Classes="muted" />
                <TextBox Text="{Binding EditableCommitMessage}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" FontFamily="Cascadia Code, Consolas, monospace" />
                <Button Content="Reset To Template" Command="{Binding ResetCommitMessageCommand}" HorizontalAlignment="Left" />
            </StackPanel>
        </Border>

        <Border Classes="card" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Approval" FontWeight="SemiBold" FontSize="16" />
                <TextBox Text="{Binding RejectReason}" PlaceholderText="Reject reason (optional)" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="primary" Content="Approve" Command="{Binding ApproveCommand}" />
                    <Button Content="Reject" Command="{Binding RejectCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding ApprovalStatusMessage}" TextWrapping="Wrap" Classes="muted" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
