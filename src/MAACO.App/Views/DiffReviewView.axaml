<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAACO.App.ViewModels"
             x:DataType="vm:DiffReviewViewModel"
             x:Class="MAACO.App.Views.DiffReviewView">
    <Border Padding="24" CornerRadius="10" Background="#112A2D34">
        <StackPanel Spacing="10">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.85" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding TaskId}" PlaceholderText="Task Id (GUID)" />
                <Button Grid.Column="1" Content="Load Diff" Command="{Binding LoadDiffCommand}" />
            </Grid>
            <TextBlock Text="{Binding DiffStatus}" />
            <TextBlock Text="Changed Files" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
            <Border Padding="8" Background="#0A141E" CornerRadius="8" Height="130">
                <ListBox ItemsSource="{Binding ChangedFiles}" />
            </Border>
            <TextBlock Text="Unified Diff" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
            <Border Padding="8" Background="#0A141E" CornerRadius="8" Height="260">
                <ScrollViewer>
                    <TextBlock Text="{Binding DiffText}" FontFamily="Cascadia Code, Consolas, monospace" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
