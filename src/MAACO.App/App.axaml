<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAACO.App.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background" Value="#0B1320" />
            <Setter Property="Foreground" Value="#E6EDF8" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Border.surface">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#14273A" />
            <Setter Property="BorderBrush" Value="#28415C" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#102235" />
            <Setter Property="BorderBrush" Value="#223A53" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.heading">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Opacity" Value="0.82" />
        </Style>
        <Style Selector="Button.nav">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="#132A3F" />
            <Setter Property="BorderBrush" Value="#233C56" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1E5AA8" />
            <Setter Property="BorderBrush" Value="#2E6AB7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="TextBox, ComboBox">
            <Setter Property="Background" Value="#0F1E2F" />
            <Setter Property="BorderBrush" Value="#2A425C" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Application.Styles>
</Application>
